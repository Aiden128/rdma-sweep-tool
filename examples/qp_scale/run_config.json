{
  "test": "ib_write_bw",
  "duration": 2,
  "use_gpu": false,
  "server": {
    "host": "rdma-server.example.com",
    "address": "rdma-server-data.example.com"
  },
  "client": {
    "host": "rdma-client.example.com"
  },
  "perftest": {
    "dir": "/opt/perftest",
    "rdma_core_lib": "",
    "env": {},
    "tmp_dir": "/tmp/rdma_sweep_{run_id}",
    "json_file": "{tmp_dir}/perftest_out.json",
    "time_file": "{tmp_dir}/perftest_time.out",
    "server_pid_file": "{tmp_dir}/perftest_server.pid",
    "server_log_file": "{tmp_dir}/perftest_server.log",
    "perf_data": "{tmp_dir}/perftest_perf.data",
    "perf_pid_file": "{tmp_dir}/perftest_perf.pid",
    "perf_record": false,
    "wait_timeout": 30,
    "default_port": 18515,
    "fixed": {
      "port": 18515,
      "msg_size": 64,
      "device": "mlx5_0",
      "gid_index": 5,
      "force_link": "Ethernet"
    }
  },
  "fixed": {
    "server": {
      "rdma_device": "mlx5_0",
      "netdev": "server-rdma-netdev",
      "mtu": 4200
    },
    "client": {
      "rdma_device": "mlx5_0",
      "netdev": "client-rdma-netdev",
      "mtu": 4200
    }
  },
  "fixed_check": {
    "server": {
      "host": "rdma-server.example.com",
      "command": "sanitized read-only fixed.server preflight",
      "returncode": 0,
      "stdout": "fixed.server check ok\n",
      "stderr": "",
      "exception": "",
      "timed_out": false
    },
    "client": {
      "host": "rdma-client.example.com",
      "command": "sanitized read-only fixed.client preflight",
      "returncode": 0,
      "stdout": "fixed.client check ok\n",
      "stderr": "",
      "exception": "",
      "timed_out": false
    }
  },
  "ssh": {
    "sudo": true,
    "connect_timeout": 10,
    "options": [
      "-o",
      "BatchMode=yes",
      "-o",
      "StrictHostKeyChecking=accept-new"
    ]
  },
  "report": {
    "title": "QP Scale RDMA Sweep",
    "subtitle": "sanitized real two-node sweep - ib_write_bw"
  }
}
